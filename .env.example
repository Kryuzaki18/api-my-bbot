PORT=3000

# A strong, randomly generated string used to sign JWT session tokens (min 16 chars)
JWT_SECRET="changeme_to_a_super_strong_random_string"

# A separate strong string used to sign/verify httpOnly cookies (min 16 chars)
COOKIE_SECRET="changeme_to_another_strong_random_string"

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/trading-bot?retryWrites=true&w=majority"

# Angular frontend origin (used for CORS credentials support)
CLIENT_ORIGIN="http://localhost:4200"

# Google Gemini API key
GEMINI_API_KEY="your_google_ai_studio_api_key"

# Anthropic Claude API key
CLAUDE_API_KEY="your_anthropic_api_key"